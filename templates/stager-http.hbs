// === EVASION FUNCTIONS ===
func randomSleep() {
	jitter := time.Duration(SLEEP_JITTER + (SLEEP_JITTER / 2)) * time.Millisecond
	time.Sleep(jitter)
}

func generateSessionID() string {
	bytes := make([]byte, 8)
	rand.Read(bytes)
	return hex.EncodeToString(bytes)
}

