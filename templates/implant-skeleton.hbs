    fn calculate_sleep(&self) -> u64 {
        let mut rng = rand::thread_rng();
        let jitter_range = (self.sleep_interval * self.jitter) / 100;
        let min_sleep = self.sleep_interval - jitter_range;
        let max_sleep = self.sleep_interval + jitter_range;
        rng.gen_range(min_sleep..=max_sleep)
    }
}

