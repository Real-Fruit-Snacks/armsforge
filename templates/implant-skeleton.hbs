    let mut fingerprint = HashMap::new();

    // Collect system information
    if let Ok(output) = execute_command("hostname", &[]) {
        fingerprint.insert("hostname".to_string(), output);
    }

    if let Ok(output) = execute_command("whoami", &[]) {
        fingerprint.insert("user".to_string(), output);
    }

    {{#ifOS "windows"}}
    if let Ok(output) = Command::new("wmic").args(&["computersystem", "get", "model"]).output() {
        fingerprint.insert("model".to_string(), String::from_utf8_lossy(&output.stdout).to_string());
    }
    {{else}}
    if let Ok(output) = Command::new("uname").args(&["-m"]).output() {
        fingerprint.insert("arch".to_string(), String::from_utf8_lossy(&output.stdout).to_string());
    }
    {{/ifOS}}

    fingerprint
}
