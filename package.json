{
  "name": "armsforge",
  "version": "0.1.0",
  "description": "Offensive security toolkit for red team operations, OSCP/OSEP prep, and engagement management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "armsforge": "bridge/cli.cjs",
    "af": "bridge/cli.cjs"
  },
  "files": [
    "dist",
    "agents",
    "bridge",
    "hooks",
    "scripts",
    "skills",
    "data",
    ".claude-plugin",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run audit:security && tsc && npm run build:mcp-server",
    "build:mcp-server": "node scripts/build-mcp-server.mjs",
    "audit:security": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "audit:check": "npm audit --audit-level=moderate",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "handlebars": "^4.7.9",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/handlebars": "^4.0.40",
    "@types/node": "^22.19.7",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Matt West",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "red-team",
    "offensive-security",
    "pentest",
    "oscp",
    "osep",
    "armsforge"
  ],
  "publishConfig": {
    "access": "public"
  }
}
